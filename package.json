{
  "name": "medix-workshop",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "test": "turbo test",
    "test:all": "npm run test && npm run e2e",
    "e2e": "npm run e2e --workspace=apps/e2e",
    "db:seed": "npm run db:seed --workspace=apps/api"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.3",
    "@types/node": "25.6.0",
    "prettier": "3.8.3",
    "turbo": "2.9.9",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
